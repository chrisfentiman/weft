#!/usr/bin/env bash
#
# Conventional Commits enforcement
# Allows: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Format: type(scope): description  OR  type: description

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
  exit 0
fi

# Conventional commit pattern
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?(!)?: .+"

if ! echo "$commit_msg" | head -1 | grep -qE "$pattern"; then
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "Expected: type(scope): description"
  echo "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  echo "Examples:"
  echo "  feat(gateway): add OpenAI-compatible endpoint"
  echo "  fix(routing): handle empty tool registries"
  echo "  chore: initial project setup"
  echo ""
  echo "Got: $(head -1 "$commit_msg_file")"
  exit 1
fi
